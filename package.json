{
  "name": "booksland-monorepo",
  "version": "1.0.0",
  "description": "Booksland monorepo with API and webapp",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --stream run dev",
    "dev:api": "pnpm --filter @booksland/api run dev",
    "dev:webapp": "pnpm --filter @booksland/webapp run dev",
    "build": "pnpm --recursive run build",
    "build:api": "pnpm --filter @booksland/api run build",
    "build:webapp": "pnpm --filter @booksland/webapp run build",
    "test": "pnpm --recursive run test",
    "test:api": "pnpm --filter @booksland/api run test",
    "test:webapp": "pnpm --filter @booksland/webapp run test",
    "typecheck": "pnpm --recursive run typecheck",
    "lint": "pnpm --recursive run lint:check"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1"
}