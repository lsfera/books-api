{
    "name": "@booksland/webapp",
    "version": "1.0.0",
    "description": "Booksland webapp with Vite + React + Effect",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "typecheck": "tsc -b --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@effect/platform": "^0.94.5",
        "@effect/schema": "^0.75.5",
        "effect": "^3.15.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@testing-library/react": "^16.1.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/ui": "^2.1.8",
        "eslint": "^9.18.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "globals": "^15.14.0",
        "jsdom": "^25.0.1",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.20.0",
        "vite": "^6.0.5",
        "vitest": "^2.1.8"
    }
}