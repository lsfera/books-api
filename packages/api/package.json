{
    "name": "@booksland/api",
    "version": "1.0.0",
    "description": "Booksland API service",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "start": "node --require ./.dist/src/monitoring/index.js ./.dist/src/index.js",
        "launch": "pnpm run build && pnpm run start",
        "prettier": "prettier --write \"./{src,test}/**/*.ts\"",
        "prettier:check": "prettier --check \"./{src,test}/**/*.ts\"",
        "lint:check": "eslint --config eslint.config.cjs \"./{src,test}/**/*.ts\"",
        "test": "NODE_OPTIONS='--import=tsx' mocha \"test/**/*.ts\"",
        "doc": "tsx ./src/spec.ts && node ./node_modules/@redocly/cli/bin/cli.js build-docs --output=./src/spec.html ./src/spec.json",
        "dev": "tsx src/index.ts",
        "dev:watch": "tsx watch src/index.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.4",
        "@eslint/js": "^10.0.1",
        "@redocly/cli": "^2.20.3",
        "@types/express": "^5.0.6",
        "@types/express-serve-static-core": "^5.1.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.3.3",
        "@types/sinon": "^21.0.0",
        "@types/sinon-express-mock": "^1.3.12",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "mocha": "^11.7.5",
        "prettier": "^3.8.1",
        "sinon": "^21.0.2",
        "sinon-express-mock": "^2.2.1",
        "swagger-autogen": "^2.23.7",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/auto-instrumentations-node": "^0.70.1",
        "@opentelemetry/exporter-metrics-otlp-proto": "^0.212.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
        "@opentelemetry/instrumentation-express": "^0.60.0",
        "@opentelemetry/instrumentation-http": "^0.212.0",
        "@opentelemetry/resources": "^2.6.0",
        "@opentelemetry/sdk-metrics": "^2.6.0",
        "@opentelemetry/sdk-node": "^0.212.0",
        "@opentelemetry/sdk-trace-node": "^2.6.0",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "@promster/express": "^15.4.6",
        "@promster/server": "^15.4.6",
        "express": "^5.2.1",
        "fp-ts": "^2.16.11",
        "io-ts": "^2.2.22",
        "io-ts-types": "^0.5.19",
        "mongodb": "^7.1.0",
        "mongoose": "^9.2.4"
    },
    "type": "module"
}